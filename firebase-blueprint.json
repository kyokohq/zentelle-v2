{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "Course": {
      "title": "Course",
      "description": "A course offered by the institution.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "instructor": { "type": "string" },
        "section": { "type": "string" },
        "tag": { "type": "string" },
        "color": { "type": "string" },
        "image": { "type": "string" },
        "code": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["title", "code"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "A user's enrollment in a course.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "courseId": { "type": "string" },
        "grade": { "type": "string" }
      },
      "required": ["uid", "courseId"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Recent activity or announcement in a course",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["discussion", "grade_update", "announcement"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "courseId": { "type": "string" },
        "uid": { "type": "string", "description": "Author UID" },
        "authorName": { "type": "string" }
      },
      "required": ["type", "title", "courseId", "uid"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A reminder for the user",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "color": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["title", "uid"]
    },
    "Event": {
      "title": "Event",
      "description": "An upcoming event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "date": { "type": "string" },
        "day": { "type": "string" },
        "month": { "type": "string" },
        "color": { "type": "string" },
        "textColor": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["title", "uid"]
    },
    "Task": {
      "title": "Task",
      "description": "A student task or assignment",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "courseId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "uid": { "type": "string" }
      },
      "required": ["title", "uid"]
    },
    "Group": {
      "title": "Group",
      "description": "A study group or club",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "uid": { "type": "string" }
      },
      "required": ["name", "uid"]
    },
    "Resource": {
      "title": "Resource",
      "description": "An educational resource",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "video", "link"] },
        "url": { "type": "string" },
        "courseId": { "type": "string" },
        "uid": { "type": "string", "description": "Uploader UID" }
      },
      "required": ["title", "type", "url", "courseId"]
    },
    "Material": {
      "title": "Material",
      "description": "A course material (folder, assignment, file, or link)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "parentId": { "type": "string", "description": "ID of the parent folder, null for top-level" },
        "type": { "type": "string", "enum": ["folder", "assignment", "file", "link"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "color": { "type": "string", "description": "Hex color for folders" },
        "googleDriveFileId": { "type": "string", "description": "ID of the file in Google Drive" },
        "googleDriveTemplateId": { "type": "string", "description": "ID of the template file for assignments" },
        "url": { "type": "string" },
        "points": { "type": "number", "description": "Maximum points for the assignment" },
        "dueDate": { "type": "string", "format": "date-time" },
        "uid": { "type": "string", "description": "Creator UID" },
        "timestamp": { "type": "string", "format": "date-time" },
        "published": { "type": "boolean", "description": "Whether the material is visible to students" },
        "order": { "type": "number", "description": "Display order of the material" }
      },
      "required": ["courseId", "type", "title", "uid", "timestamp"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A student's submission for an assignment",
      "type": "object",
      "properties": {
        "materialId": { "type": "string" },
        "uid": { "type": "string", "description": "Student UID" },
        "googleDriveFileId": { "type": "string", "description": "ID of the student's copy in Google Drive" },
        "fileUrl": { "type": "string", "description": "URL of the uploaded file" },
        "textSubmission": { "type": "string", "description": "Text content of the submission" },
        "status": { "type": "string", "enum": ["draft", "submitted"] },
        "grade": { "type": "number", "description": "Grade assigned to the submission" },
        "feedback": { "type": "string", "description": "Instructor feedback" },
        "studentName": { "type": "string", "description": "Name of the student" },
        "submittedAt": { "type": "string", "format": "date-time", "description": "When the assignment was submitted" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["materialId", "uid", "googleDriveFileId", "status", "timestamp"]
    },
    "CourseMessage": {
      "title": "CourseMessage",
      "description": "A message in a course discussion",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "text": { "type": "string" },
        "uid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "text", "uid", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course information"
    },
    "/enrollments/{enrollmentId}": {
      "schema": "Enrollment",
      "description": "User course enrollments"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Activity feed items"
    },
    "/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "User reminders"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Upcoming events"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Student tasks"
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Study groups"
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Educational resources"
    },
    "/course_messages/{messageId}": {
      "schema": "CourseMessage",
      "description": "Course discussion messages"
    },
    "/materials/{materialId}": {
      "schema": "Material",
      "description": "Course materials"
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Assignment submissions"
    }
  }
}
